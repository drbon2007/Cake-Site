{
  "version": 2,
  "name": "cake-recipe-book",
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/recipes/(.*)", "destination": "/api/index" },
    { "source": "/ingredients/(.*)", "destination": "/api/index" },
    { "source": "/reviews/(.*)", "destination": "/api/index" },
    { "source": "/tips/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "trailingSlash": false
}
