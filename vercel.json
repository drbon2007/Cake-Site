{
  "version": 2,
  "name": "sweet-bake-studio",
  "functions": {
    "api/recipes.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/ingredients/(.*)", "destination": "/api/recipes" },
    { "source": "/api/timer/(.*)", "destination": "/api/recipes" },
    { "source": "/recipe/(.*)", "destination": "/api/recipes" },
    { "source": "/bake/(.*)", "destination": "/api/recipes" }
  ],
  "trailingSlash": false
}
